{
  "name": "pi-desktop-mock",
  "version": "0.1.0",
  "private": true,
  "description": "Codex-inspired desktop UI mock for Pi",
  "packageManager": "bun@1.3.9",
  "main": "build/electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"bun run dev:web\" \"bun run dev:electron:tsc\" \"bun run dev:electron\"",
    "dev:web": "vite",
    "dev:electron:tsc": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 build/electron/main.cjs && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build && bun run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "prepare": "test -d .git && husky || true",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "bun run typecheck:web && bun run typecheck:electron",
    "typecheck:web": "tsc --noEmit",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cts,mts,cjs,mjs,json,css,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/vite": "^4.1.8",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^37.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.7",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3"
  }
}
