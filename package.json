{
  "name": "pi-desktop-mock",
  "version": "0.1.2",
  "private": true,
  "description": "Desktop coding app for Pi with projects, terminal, git, and diff workflows.",
  "license": "MIT",
  "author": "Igor Warzocha",
  "main": "build/electron/main/index.cjs",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "dev": "npm run dev:clean && concurrently -k \"npm:dev:web\" \"npm:dev:runtime\" \"npm:dev:desktop\"",
    "dev:clean": "rm -rf artifacts/electron build/electron build/desktop build/dev-server.json",
    "dev:web": "node --import tsx ./scripts/dev-web.ts",
    "dev:runtime": "node --import tsx ./scripts/build-electron-runtime.ts --watch",
    "dev:desktop": "node --import tsx ./scripts/dev-electron.ts",
    "build": "vite build && node --import tsx ./scripts/build-electron-runtime.ts && electron-builder --dir --config electron-builder.yml",
    "build:release": "vite build && node --import tsx ./scripts/build-electron-runtime.ts && electron-builder --dir --config electron-builder.yml",
    "build:launcher-artifacts": "node --import tsx ./scripts/package-launcher-artifacts.ts",
    "release:prepare": "npm run build:release && npm run build:launcher-artifacts",
    "pack:howcode": "cd packages/howcode && npm pack",
    "publish:howcode:dry-run": "cd packages/howcode && npm publish --dry-run",
    "preview": "vite preview",
    "prepare": "test -d .git && husky || true",
    "postinstall": "electron-builder install-app-deps",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "npm run typecheck:web && npm run typecheck:desktop && npm run typecheck:electron && npm run typecheck:scripts",
    "typecheck:web": "tsc --noEmit",
    "typecheck:desktop": "tsc -p tsconfig.desktop.json --noEmit",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cts,mts,cjs,mjs,json,css,md}": ["biome check --no-errors-on-unmatched"]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@mariozechner/pi-agent-core": "^0.67.6",
    "@mariozechner/pi-ai": "^0.67.6",
    "@mariozechner/pi-coding-agent": "^0.67.6",
    "@mariozechner/pi-tui": "^0.67.6",
    "@pierre/diffs": "^1.1.0-beta.16",
    "@tanstack/react-pacer": "^0.21.1",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-virtual": "^3.13.23",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.2.0",
    "lucide-react": "^0.525.0",
    "node-pty": "^1.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sherpa-onnx-node": "^1.12.38"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/vite": "^4.1.8",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.0",
    "electron": "41.2.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.9",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.7",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
