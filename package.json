{
  "name": "pi-desktop-mock",
  "version": "0.1.0",
  "private": true,
  "description": "Codex-inspired desktop UI mock for Pi",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "bun run dev:clean && concurrently -k \"bun run dev:web\" \"bun run dev:desktop:build\" \"bun run dev:desktop\"",
    "dev:clean": "rm -rf build/dev-linux-x64 build/desktop",
    "dev:web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:desktop:build": "bun --watch ./scripts/build-desktop-backend.ts",
    "dev:desktop": "sh -c 'until [ -f build/desktop/pi-threads.mjs ] && [ -f build/desktop/terminal-manager.mjs ]; do sleep 0.2; done; WEBKIT_DISABLE_DMABUF_RENDERER=1 electrobun dev --watch'",
    "build": "vite build && bun run build:desktop && electrobun build",
    "build:desktop": "bun run ./scripts/build-desktop-backend.ts",
    "preview": "vite preview",
    "prepare": "test -d .git && husky || true",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "bun run typecheck:web && bun run typecheck:desktop",
    "typecheck:web": "tsc --noEmit",
    "typecheck:desktop": "tsc -p tsconfig.bun.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cts,mts,cjs,mjs,json,css,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@pierre/diffs": "^1.1.0-beta.16",
    "@tanstack/react-pacer": "^0.21.1",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/bun": "^1.3.11",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electrobun": "1.17.1-beta.0",
    "lucide-react": "^0.525.0",
    "node-pty": "^1.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/vite": "^4.1.8",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.7",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
